*&      Form  FRM_DISPLAY_DATA
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM frm_display_data .

* Variables for ALV
  DATA: l_title TYPE lvc_title  "Title
      , ls_vari TYPE disvariant "Variant
      , ls_layo TYPE lvc_s_layo "Layout
      , ls_glay TYPE lvc_s_glay "Grid settings
      , lt_fcat TYPE lvc_t_fcat "Field Catalog Table
      , lt_evts TYPE lvc_t_evts "Events Table
      , lt_evts_exit TYPE slis_t_event_exit
      .


* Title
  l_title = sy-title.

* Layout
  ls_layo-cwidth_opt = 'X'.
  ls_layo-zebra      = 'X'.
*  LS_LAYO-SMALLTITLE      = 'X'.
*  LS_LAYO-BOX_FNAME      = 'CHBOX'.
*  ls_layo-info_fname = 'COLOR' .

* Field Catalog Table
  PERFORM frm_build_fcat USING lt_fcat.


* Show ALV
  CALL FUNCTION 'REUSE_ALV_GRID_DISPLAY_LVC'
    EXPORTING
      i_callback_program       = sy-repid
      i_callback_pf_status_set = 'FRM_PF_STATUS_SET'
      i_callback_user_command  = 'FRM_USER_COMMAND'
*     I_GRID_TITLE             = L_TITLE
      i_save                   = 'A'
      is_variant               = ls_vari
      is_layout_lvc            = ls_layo
      i_grid_settings          = ls_glay
      it_fieldcat_lvc          = lt_fcat
    TABLES
      t_outtab                 = gt_out
    EXCEPTIONS
      program_error            = 1
      OTHERS                   = 2.



ENDFORM.




