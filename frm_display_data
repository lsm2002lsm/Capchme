*&---------------------------------------------------------------------*
*&      Form  FRM_ADD_FIELD
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_IT_FCAT  text
*      -->P_0110   text
*      -->P_0111   text
*      -->P_0112   text
*      -->P_0113   text
*----------------------------------------------------------------------*
FORM frm_add_field USING   it_fcat     TYPE lvc_t_fcat
                             i_fieldname TYPE lvc_fname
                             i_ref_tab  TYPE  lvc_rtname
                             i_ref_field TYPE  lvc_rfname
                             i_reptext   TYPE reptext .
  "i_output    TYPE lvc_outlen .

  DATA: ls_fcat TYPE lvc_s_fcat.
*  LS_FCAT-TABNAME   = 'GT_OUT'.
*  LS_FCAT-REF_TABLE = 'ZZQMT001'.
  ls_fcat-fieldname = i_fieldname. "字段名称
  ls_fcat-ref_table = i_ref_tab .
  ls_fcat-ref_field = i_ref_field. "字段名称
  ls_fcat-reptext   = i_reptext.   "标题
  ls_fcat-coltext   = i_reptext.   "列标题
*  ls_fcat-outputlen = i_output .
*  LS_FCAT-LZERO     = ''.          "输出前导零
*  ls_fcat-no_zero   = 'X'.          "隐藏零
*  LS_FCAT-EMPHASIZE = 'C310'.      "列颜色
*  LS_FCAT-CHECKBOX  = ''.          "作为复选框输出
*  LS_FCAT-DECIMALS  = 0.           "小数位数
* 特殊处理(仅改变显示样式,不应涉及逻辑)
  CASE ls_fcat-fieldname.
    WHEN 'CHBOX'.
      ls_fcat-key  = 'X'.
      ls_fcat-edit = 'X'.
      ls_fcat-checkbox = 'X'.
    WHEN 'ICON'.
      ls_fcat-key = 'X'.
      ls_fcat-icon = 'X' .
    WHEN 'TABIX'.
      ls_fcat-key  = 'X'.
*    WHEN 'MEINS' .
*      ls_fcat-edit_mask = '==CUNIT'.
*    WHEN 'VBELN'  OR 'KUNNR' .
*      ls_fcat-no_zero = 'X' .
*
*    WHEN 'MATNR' .
*      ls_fcat-no_zero = 'X' .
*      ls_fcat-ref_table = 'VBAP' .
*      ls_fcat-ref_field = 'MATNR' .

    WHEN OTHERS.
  ENDCASE.

* 添加
  APPEND ls_fcat TO it_fcat.
  CLEAR  ls_fcat.


ENDFORM.


