MODULE pai_9001 INPUT.

  g_ucomm = ok_code.
  CLEAR ok_code.

  CASE g_ucomm.
    WHEN 'BACK' OR 'EXIT'.
      PERFORM frm_free_object .
      LEAVE TO SCREEN 0 .

    WHEN 'CANCEL' .
      LEAVE PROGRAM .
  ENDCASE .

ENDMODULE.
