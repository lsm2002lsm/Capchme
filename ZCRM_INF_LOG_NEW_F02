FORM frm_set_screen .

  DATA : lo_doc_left TYPE REF TO cl_dd_document .
  DATA : lo_doc_right TYPE REF TO cl_dd_document .


  CHECK go_dock IS INITIAL .

  CREATE OBJECT go_dock
    EXPORTING
      dynnr     = sy-dynnr
      repid     = sy-cprog
      side      = 2          "SPLIT SCROLL BAR
      extension = 2000.      "


  CREATE OBJECT go_split_mid
    EXPORTING
      parent            = go_dock
      rows              = 2
      columns           = 1
    EXCEPTIONS
      cntl_error        = 1
      cntl_system_error = 2
      OTHERS            = 3.


  CALL METHOD go_split_mid->get_container
    EXPORTING
      row       = 1
      column    = 1
    RECEIVING
      container = go_cont_top.


  CALL METHOD go_split_mid->get_container
    EXPORTING
      row       = 2
      column    = 1
    RECEIVING
      container = go_cont_bot.



  CREATE OBJECT go_split_bot
    EXPORTING
      parent            = go_cont_bot
      rows              = 1
      columns           = 2
    EXCEPTIONS
      cntl_error        = 1
      cntl_system_error = 2
      OTHERS            = 3.


  CALL METHOD go_split_bot->get_container
    EXPORTING
      row       = 1
      column    = 1
    RECEIVING
      container = go_cont_bot_left.


*  CREATE OBJECT lo_doc_left
*    EXPORTING
*      no_margins = 'X'.
*
*  CALL METHOD lo_doc_left->add_text
*    EXPORTING
*      text      = 'Request'
*      sap_style = cl_dd_area=>heading.
*
*  CALL METHOD lo_doc_left->display_document
*    EXPORTING
*      parent = go_cont_bot_left.





  CALL METHOD go_split_bot->get_container
    EXPORTING
      row       = 1
      column    = 2
    RECEIVING
      container = go_cont_bot_right.


*  CREATE OBJECT lo_doc_right
*    EXPORTING
*      no_margins = 'X'.
*
*  CALL METHOD lo_doc_right->add_text
*    EXPORTING
*      text      = 'Response'
*      sap_style = cl_dd_area=>heading.
*
*  CALL METHOD lo_doc_right->display_document
*    EXPORTING
*      parent = go_cont_bot_right.


ENDFORM.
