*& text
*&---------------------------------------------------------------------*
*& -->  p1        text
*& <--  p2        text
*&---------------------------------------------------------------------*
FORM frm_create_alv .


  CHECK gr_alv IS INITIAL .

  CREATE OBJECT gr_alv
    EXPORTING
      i_parent = go_cont_top.


  DATA : lr_hdl_all TYPE REF TO lcl_event_handler_all .

  CREATE OBJECT lr_hdl_all.
  SET HANDLER lr_hdl_all->toolbar                FOR gr_alv .
  SET HANDLER lr_hdl_all->user_command           FOR gr_alv .
  SET HANDLER lr_hdl_all->hotspot_click          FOR gr_alv .
  SET HANDLER lr_hdl_all->double_click           FOR gr_alv .
  SET HANDLER lr_hdl_all->before_user_command    FOR gr_alv .
  SET HANDLER lr_hdl_all->after_user_command     FOR gr_alv .
  SET HANDLER lr_hdl_all->data_changed           FOR gr_alv .
  SET HANDLER lr_hdl_all->data_changed_finished  FOR gr_alv .
  SET HANDLER lr_hdl_all->menu_button            FOR gr_alv .
  SET HANDLER lr_hdl_all->button_click           FOR gr_alv .
  SET HANDLER lr_hdl_all->after_refresh          FOR gr_alv .
  SET HANDLER lr_hdl_all->onf4                   FOR gr_alv .
  SET HANDLER lr_hdl_all->ondropcomplete         FOR gr_alv .


  gs_vari-report = sy-repid.
  gs_layo-cwidth_opt = 'X' .
*  gs_layo-info_fname = 'COLOR' . " 颜色
*  gs_layo-no_rowmark = 'X' .
*  gs_layo-grid_title =  .

  PERFORM frm_build_fcat USING gt_fcat .
  PERFORM frm_build_sort USING gt_sort .


  CALL METHOD gr_alv->set_table_for_first_display
    EXPORTING
      is_variant           = gs_vari
      is_layout            = gs_layo
      i_save               = 'A'
      i_buffer_active      = space
      i_bypassing_buffer   = space
      it_toolbar_excluding = gt_excl
    CHANGING
      it_outtab            = gt_out
      it_sort              = gt_sort
      it_fieldcatalog      = gt_fcat.


ENDFORM.
*&---------------------------------------------------------------------*
*& Form frm_build_fcat
*&---------------------------------------------------------------------*
*& text
*&---------------------------------------------------------------------*
*&      --> GT_FCAT
*&---------------------------------------------------------------------*
FORM frm_build_fcat  USING it_fcat TYPE lvc_t_fcat .

  REFRESH it_fcat .

  PERFORM frm_add_field USING:
    it_fcat  'ICON'                '标识' ,
    it_fcat  'MSG'                 '消息',

    it_fcat  'ZINFID'                '接口编号',
    it_fcat  'ZINF_T'                '接口描述',
    it_fcat  'ZDIRECT_T'             '接口方向',
    it_fcat  'OBJID'                 '对象编号',
    it_fcat  'ZDATE'                 '日期',
    it_fcat  'ZTIME'                 '时间',
    it_fcat  'ISPGI'                 'PGI Flag'.

*          zinf_t   TYPE char30,
*          zdirect_t  TYPE char30,
ENDFORM.
*&---------------------------------------------------------------------*
*& Form frm_add_field
*&---------------------------------------------------------------------*
*& text
*&---------------------------------------------------------------------*
*&      --> IT_FCAT
*&      --> P_
*&      --> P_
*&---------------------------------------------------------------------*
FORM frm_add_field USING   it_fcat     TYPE lvc_t_fcat
                             i_fieldname TYPE lvc_fname
                             i_reptext   TYPE reptext .
  "i_output    TYPE lvc_outlen .

  DATA: ls_fcat TYPE lvc_s_fcat.
*  LS_FCAT-TABNAME   = 'GT_OUT'.
*  LS_FCAT-REF_TABLE = 'ZZQMT001'.
  ls_fcat-fieldname = i_fieldname. "字段名称
  ls_fcat-ref_field = i_fieldname. "字段名称
  ls_fcat-reptext   = i_reptext.   "标题
  ls_fcat-coltext   = i_reptext.   "列标题
*  ls_fcat-outputlen = i_output .
*  LS_FCAT-LZERO     = ''.          "输出前导零
  ls_fcat-no_zero   = 'X'.          "隐藏零
*  LS_FCAT-EMPHASIZE = 'C310'.      "列颜色
*  LS_FCAT-CHECKBOX  = ''.          "作为复选框输出
*  LS_FCAT-DECIMALS  = 0.           "小数位数
* 特殊处理(仅改变显示样式,不应涉及逻辑)
  CASE ls_fcat-fieldname.
    WHEN 'CHBOX'.
      ls_fcat-key  = 'X'.
      ls_fcat-edit = 'X'.
      ls_fcat-checkbox = 'X'.
    WHEN 'ICON'.
      ls_fcat-key = 'X'.
      ls_fcat-icon = 'X' .
    WHEN 'TABIX'.
      ls_fcat-key  = 'X'.
    WHEN OTHERS.
  ENDCASE.

* 添加
  APPEND ls_fcat TO it_fcat.
  CLEAR  ls_fcat.


ENDFORM.
