      data = gs_resp.


  CALL METHOD lo_http_client->close.


  IF gs_resp-code = 200 .
    p_msgtyp = 'S' .
    p_msg = 'SUCCESS' .
  ELSE .

    p_msgtyp = 'E' .
    p_msg = gs_resp-error .

  ENDIF .



