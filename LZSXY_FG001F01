FORM frm_send_to_crm USING p_dn TYPE  likp-vbeln
                           ps_insert_conf TYPE zfs_t_001
                           ps_del_conf TYPE zfs_t_001
                     CHANGING p_msgtyp TYPE bapi_mtype
                              p_msg TYPE bapi_msg
                              p_request TYPE string
                              p_response TYPE string .



  DATA : lv_request_json TYPE string .

  DATA name_mappings TYPE zcl_ui2_json=>name_mappings .

  INSERT VALUE zcl_ui2_json=>name_mapping( abap = 'VBELN'   json = 'name')      INTO TABLE name_mappings .
  INSERT VALUE zcl_ui2_json=>name_mapping( abap = 'KDRQ'   json = 'KDRQ__c')      INTO TABLE name_mappings .
  INSERT VALUE zcl_ui2_json=>name_mapping( abap = 'YSFS'   json = 'YSFS__c')      INTO TABLE name_mappings .
  INSERT VALUE zcl_ui2_json=>name_mapping( abap = 'BZ'   json = 'BZ__c')      INTO TABLE name_mappings .
  INSERT VALUE zcl_ui2_json=>name_mapping( abap = 'SHDZ'   json = 'SHDZ__c')      INTO TABLE name_mappings .
  INSERT VALUE zcl_ui2_json=>name_mapping( abap = 'SALESORDER'   json = 'OrderName__c')      INTO TABLE name_mappings .
  INSERT VALUE zcl_ui2_json=>name_mapping( abap = 'ZT'   json = 'ZT__c')      INTO TABLE name_mappings .
  INSERT VALUE zcl_ui2_json=>name_mapping( abap = 'BOLNR'   json = 'BOLNR')      INTO TABLE name_mappings .
  INSERT VALUE zcl_ui2_json=>name_mapping( abap = 'T_ITEM'   json = 'details')      INTO TABLE name_mappings .
  INSERT VALUE zcl_ui2_json=>name_mapping( abap = 'POSNR'   json = 'SAPOrderLine__c')      INTO TABLE name_mappings .
  INSERT VALUE zcl_ui2_json=>name_mapping( abap = 'MATNR'   json = 'WLBM__c')      INTO TABLE name_mappings .
  INSERT VALUE zcl_ui2_json=>name_mapping( abap = 'MENGE'   json = 'SL__c')      INTO TABLE name_mappings .
  INSERT VALUE zcl_ui2_json=>name_mapping( abap = 'DW'   json = 'DW__c')      INTO TABLE name_mappings .
  INSERT VALUE zcl_ui2_json=>name_mapping( abap = 'SERNR'   json = 'SerialNumber__c')      INTO TABLE name_mappings .
  INSERT VALUE zcl_ui2_json=>name_mapping( abap = 'CHARG'   json = 'Batch__c')      INTO TABLE name_mappings .
  INSERT VALUE zcl_ui2_json=>name_mapping( abap = 'ZZJE'   json = 'ZJE__c')      INTO TABLE name_mappings .
  INSERT VALUE zcl_ui2_json=>name_mapping( abap = 'ZX'   json = 'ZX__c')      INTO TABLE name_mappings .
  INSERT VALUE zcl_ui2_json=>name_mapping( abap = 'KDDH'   json = 'KDDH')      INTO TABLE name_mappings .
  INSERT VALUE zcl_ui2_json=>name_mapping( abap = 'JSFPH'   json = 'JSFPH')      INTO TABLE name_mappings .
  INSERT VALUE zcl_ui2_json=>name_mapping( abap = 'JPSL'   json = 'JPSL')      INTO TABLE name_mappings .
  INSERT VALUE zcl_ui2_json=>name_mapping( abap = 'REF_DOC'   json = 'REF_DOC')      INTO TABLE name_mappings .
  INSERT VALUE zcl_ui2_json=>name_mapping( abap = 'REF_ITEM'   json = 'REF_ITEM')      INTO TABLE name_mappings .
  INSERT VALUE zcl_ui2_json=>name_mapping( abap = 'REF_TYPE'   json = 'REF_TYPE')      INTO TABLE name_mappings .
  INSERT VALUE zcl_ui2_json=>name_mapping( abap = 'ZPR1'   json = 'ZPR1')      INTO TABLE name_mappings .
  INSERT VALUE zcl_ui2_json=>name_mapping( abap = 'ZPR2'   json = 'ZPR2')      INTO TABLE name_mappings .
  INSERT VALUE zcl_ui2_json=>name_mapping( abap = 'ZMW1'   json = 'ZMW1')      INTO TABLE name_mappings .
  INSERT VALUE zcl_ui2_json=>name_mapping( abap = 'ZMW2'   json = 'ZMW2')      INTO TABLE name_mappings .
  INSERT VALUE zcl_ui2_json=>name_mapping( abap = 'KPZT'   json = 'KPZT')      INTO TABLE name_mappings .



  CALL METHOD zcl_ui2_json=>serialize
    EXPORTING
      data          = gs_dn
      compress      = abap_true
*     name          =
*     pretty_name   = PRETTY_MODE-NONE
*     type_descr    =
*     assoc_arrays  = C_BOOL-FALSE
*     ts_as_iso8601 = C_BOOL-FALSE
*     expand_includes  = C_BOOL-TRUE
*     assoc_arrays_opt = C_BOOL-FALSE
*     numc_as_string   = C_BOOL-FALSE
      name_mappings = name_mappings
*     conversion_exits = C_BOOL-FALSE
*     format_output = C_BOOL-FALSE
*     hex_as_base64 = C_BOOL-TRUE
    RECEIVING
      r_json        = lv_request_json.


