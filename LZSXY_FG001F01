  p_request = lv_request_json .

  cl_http_client=>create_by_url(
             EXPORTING url    = lv_url
             IMPORTING client = lo_http_client ).

  lo_http_client->request->set_header_field(
          EXPORTING
               name  = 'Content-Type'
               value = 'application/json' ).

  lo_http_client->request->set_header_field(
          EXPORTING
               name  = lv_header_name
               value = lv_header_value ).

  CALL METHOD lo_http_client->request->set_method( 'POST' ).

  CALL METHOD lo_http_client->request->set_cdata
    EXPORTING
      data = lv_request_body.


  CALL METHOD lo_http_client->send
    EXCEPTIONS
      http_communication_failure = 1
      http_invalid_state         = 2.


  "receipt of http response
  CALL METHOD lo_http_client->receive
    EXCEPTIONS
      http_communication_failure = 1
      http_invalid_state         = 2
      http_processing_failed     = 3.

  CASE  sy-subrc .
    WHEN 1.
      p_msgtyp = 'E' .
      p_msg = 'HTTP Error:' && 'http_communication_failure' .
      RETURN .
    WHEN 2.
      p_msgtyp = 'E' .
      p_msg = 'HTTP Error:' && 'http_invalid_state' .
      RETURN .
    WHEN 3.
      p_msgtyp = 'E' .
      p_msg = 'HTTP Error:' && 'http_processing_failed' .
      RETURN .
    WHEN OTHERS.
  ENDCASE.


  lv_resp_json = lo_http_client->response->get_cdata( ).
  p_response = lv_resp_json .

